---
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith("/") ? raw : raw + "/";

const ghEngine = "https://github.com/GetTechAPI/TechEngine";
const ghData = "https://github.com/Seungpyo1007/TechAPI";

const pillars = [
  {
    title: "Validate",
    blurb: "Schema, slug, range, and uniqueness checks gate every PR to the dataset.",
    cmd: "python -m app.validate",
    link: `${ghEngine}/blob/main/app/validate.py`,
  },
  {
    title: "Cover",
    blurb: "Diff the curated dataset against upstream catalogs (ARK, AMD, Wikipedia) and surface missing SKUs as weekly reports.",
    cmd: "python -m app.coverage",
    link: `${ghEngine}/issues/1`,
    pending: true,
  },
  {
    title: "Ingest",
    blurb: "Drafts new records from canonical sources and opens PRs against TechAPI for human review.",
    cmd: "python -m app.ingest",
    link: `${ghEngine}/issues/2`,
    pending: true,
  },
];

const workflows = [
  { name: "validate-data", file: "validate-data.yml", desc: "Reusable: called by TechAPI on every PR + push." },
  { name: "refresh-data", file: "refresh-data.yml", desc: "Cron Mondays 06:17 UTC — regenerates the static dump." },
  { name: "test", file: "test.yml", desc: "Lint + type-check + pytest on every push." },
  { name: "deploy-pages", file: "deploy-pages.yml", desc: "Builds this site + dump and publishes to Pages." },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>TechEngine — validation & ingestion for the TechAPI dataset</title>
  <meta name="description" content="The engine that validates, fills, and serves the TechAPI dataset. Schema checks, coverage diffs against upstream catalogs, and a weekly ingestion crawler that opens PRs." />
</head>
<body>
  <div class="bg-grid" aria-hidden="true"></div>

  <nav class="nav">
    <div class="wrap nav-inner">
      <a class="brand" href={base}>
        <span class="dot"></span> TechEngine
      </a>
      <div class="nav-links">
        <a href="#pillars">What it does</a>
        <a href="#status">Status</a>
        <a href="#workflows">Workflows</a>
        <a href={`${base}docs`}>API docs</a>
        <a href={ghData} target="_blank" rel="noopener">TechAPI ↗</a>
        <a class="nav-gh" href={ghEngine} target="_blank" rel="noopener">GitHub ↗</a>
      </div>
    </div>
  </nav>

  <header class="hero">
    <div class="wrap">
      <span class="pill">⚙️ Validation · coverage · ingestion · serving</span>
      <h1>The engine behind <a href={ghData} target="_blank" rel="noopener" class="grad">TechAPI</a></h1>
      <p class="tagline">
        TechEngine validates every change to the dataset, diffs it against upstream
        catalogs to surface what is missing, and (next) drafts new records
        automatically so curators only review.
      </p>
      <div class="cta">
        <a class="btn primary" href={`${base}docs`}>Read API docs →</a>
        <a class="btn ghost" href={ghEngine} target="_blank" rel="noopener">View on GitHub ↗</a>
      </div>
      <div class="stats" id="stats">
        <div class="stat skeleton"><div class="n">—</div><div class="l">loading</div></div>
      </div>
    </div>
  </header>

  <main class="wrap">
    <!-- ─────────────── Pillars ─────────────── -->
    <section id="pillars">
      <div class="sec-head">
        <h2>Three pillars</h2>
        <p class="sec-sub">Each pillar is a Python module under <code>app/</code>; CI orchestrates them.</p>
      </div>
      <div class="hiw">
        {pillars.map((p) => (
          <div class={`hiw-card pillar${p.pending ? " pending" : ""}`}>
            <div class="pillar-row">
              <h3>{p.title}</h3>
              {p.pending && <span class="badge">planned</span>}
            </div>
            <p>{p.blurb}</p>
            <code class="cmd">$ {p.cmd}</code>
            <a class="more" href={p.link} target="_blank" rel="noopener">
              {p.pending ? "Roadmap →" : "Source →"}
            </a>
          </div>
        ))}
      </div>
    </section>

    <!-- ─────────────── Status ─────────────── -->
    <section id="status">
      <div class="sec-head">
        <h2>Status</h2>
        <p class="sec-sub">Pulled from the static dump's manifest. Populates once <code>refresh-data</code> has run.</p>
      </div>
      <div class="pg">
        <div class="pg-reqline">
          <span class="method">GET</span>
          <code>/v1/index.json</code>
          <span class="spacer"></span>
          <span id="status-pill" class="status pending">…</span>
        </div>
        <pre class="pg-out"><code id="status-out">Loading…</code></pre>
      </div>
    </section>

    <!-- ─────────────── Pipeline ─────────────── -->
    <section>
      <div class="sec-head">
        <h2>How the two repos connect</h2>
        <p class="sec-sub">
          The dataset lives in <a href={ghData} target="_blank" rel="noopener">TechAPI</a>.
          TechEngine reads it via a sibling checkout, validates, and emits artifacts.
        </p>
      </div>
      <div class="flow">
        <div class="flow-card">
          <div class="flow-head">TechAPI</div>
          <div class="flow-body">
            <code>data/</code><br/>
            <code>app/validate.py</code> (self-check)
          </div>
        </div>
        <div class="flow-arrow">
          <div class="flow-arrow-label">workflow_call</div>
          <div class="flow-arrow-line">⟶</div>
          <div class="flow-arrow-label muted">checkout sibling</div>
        </div>
        <div class="flow-card">
          <div class="flow-head">TechEngine</div>
          <div class="flow-body">
            <code>app/validate.py</code> (heavy)<br/>
            <code>app/seed.py · dump.py</code><br/>
            <span class="muted">app/coverage · app/ingest (planned)</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ─────────────── Workflows ─────────────── -->
    <section id="workflows">
      <div class="sec-head">
        <h2>Workflows</h2>
        <p class="sec-sub">CI surface lives in <code>.github/workflows/</code>.</p>
      </div>
      <ul class="ep">
        {workflows.map((w) => (
          <li>
            <a href={`${ghEngine}/blob/main/.github/workflows/${w.file}`} target="_blank" rel="noopener">
              <span class="method">YAML</span>
              <span class="ep-path">{w.name}</span>
              <span class="ep-desc">{w.desc}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- ─────────────── Roadmap ─────────────── -->
    <section>
      <div class="sec-head">
        <h2>Roadmap</h2>
        <p class="sec-sub">Each line is a tracked GitHub issue.</p>
      </div>
      <ul class="ep">
        <li>
          <a href={`${ghEngine}/issues/1`} target="_blank" rel="noopener">
            <span class="method">#1</span>
            <span class="ep-path">coverage gap detector</span>
            <span class="ep-desc">Diff curated dataset vs upstream catalogs; weekly report.</span>
          </a>
        </li>
        <li>
          <a href={`${ghEngine}/issues/2`} target="_blank" rel="noopener">
            <span class="method">#2</span>
            <span class="ep-path">ingestion crawler</span>
            <span class="ep-desc">Weekly automated PRs to TechAPI with proposed new SKUs.</span>
          </a>
        </li>
      </ul>
    </section>
  </main>

  <footer class="wrap">
    <p>TechEngine · code <strong>MIT</strong> · dataset lives at <a href={ghData} target="_blank" rel="noopener">TechAPI</a> (CC-BY-SA 4.0).</p>
    <p><a href={ghEngine} target="_blank" rel="noopener">GitHub</a> · <a href={`${base}docs`}>API reference</a></p>
  </footer>

  <script>
    const raw = import.meta.env.BASE_URL;
    const base = raw.endsWith("/") ? raw : raw + "/";
    const esc = (s) => String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");

    function highlightJSON(obj) {
      const json = esc(JSON.stringify(obj, null, 2));
      return json.replace(
        /("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false)\b|\bnull\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g,
        (m) => {
          let cls = "j-num";
          if (/^"/.test(m)) cls = /:$/.test(m) ? "j-key" : "j-str";
          else if (/true|false/.test(m)) cls = "j-bool";
          else if (/null/.test(m)) cls = "j-null";
          return `<span class="${cls}">${m}</span>`;
        }
      );
    }

    async function getJSON(path) {
      const r = await fetch(base + path);
      if (!r.ok) throw new Error(r.status + " " + r.statusText);
      return r.json();
    }

    function countUp(el, target) {
      const dur = 800, t0 = performance.now();
      function tick(t) {
        const p = Math.min(1, (t - t0) / dur);
        el.textContent = Math.round(target * (1 - Math.pow(1 - p, 3))).toLocaleString();
        if (p < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    getJSON("v1/index.json").then((m) => {
      const order = ["smartphones", "socs", "gpus", "cpus", "brands"];
      const el = document.getElementById("stats");
      el.innerHTML = "";
      for (const k of order) {
        const c = m.collections?.[k]?.count;
        if (c == null) continue;
        el.insertAdjacentHTML("beforeend",
          `<div class="stat"><div class="n" data-n="${c}">0</div><div class="l">${k}</div></div>`);
      }
      el.querySelectorAll(".n").forEach((n) => countUp(n, +n.dataset.n));
      // Mirror the manifest into the status panel.
      const pill = document.getElementById("status-pill");
      pill.textContent = "200 OK";
      pill.className = "status ok";
      document.getElementById("status-out").innerHTML = highlightJSON(m);
    }).catch((e) => {
      document.getElementById("stats").innerHTML =
        '<div class="stat"><div class="n">—</div><div class="l">run refresh-data</div></div>';
      const pill = document.getElementById("status-pill");
      pill.textContent = "no dump yet";
      pill.className = "status err";
      document.getElementById("status-out").innerHTML =
        '<span class="j-null">No dump artifact deployed yet. Trigger the refresh-data workflow to populate this panel.</span>';
    });
  </script>

  <style is:global>
    :root {
      --bg:#0a0d14; --panel:#121826; --panel2:#0f1420; --fg:#e8ebf2; --muted:#94a0b3;
      --accent:#5b9dff; --accent2:#8b5cf6; --green:#7ee787; --amber:#ffd479; --red:#ff7b8a;
      --border:#1e2636; --border2:#2a3346; --radius:14px;
    }
    * { box-sizing:border-box; }
    html { scroll-behavior:smooth; }
    body { margin:0; font:16px/1.6 -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
      background:var(--bg); color:var(--fg); -webkit-font-smoothing:antialiased; }
    a { color:var(--accent); text-decoration:none; } a:hover { color:#8fbcff; }
    h1,h2,h3 { letter-spacing:-.02em; }
    code { font-family:ui-monospace,SFMono-Regular,Menlo,monospace; }
    .wrap { max-width:1040px; margin:0 auto; padding:0 22px; }
    .grad { background:linear-gradient(95deg,var(--accent),var(--accent2)); -webkit-background-clip:text; background-clip:text; color:transparent; }
    .muted { color:var(--muted); }

    .bg-grid { position:fixed; inset:0; z-index:-1; pointer-events:none;
      background:
        radial-gradient(900px 420px at 50% -8%, rgba(91,157,255,.16), transparent 70%),
        radial-gradient(700px 380px at 85% 8%, rgba(139,92,246,.12), transparent 70%),
        linear-gradient(transparent 0, var(--bg) 600px),
        linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px) 0 0/44px 44px,
        linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px) 0 0/44px 44px; }

    .nav { position:sticky; top:0; z-index:20; backdrop-filter:blur(10px);
      background:rgba(10,13,20,.72); border-bottom:1px solid var(--border); }
    .nav-inner { display:flex; align-items:center; justify-content:space-between; height:58px; }
    .brand { display:flex; align-items:center; gap:9px; font-weight:800; font-size:18px; color:var(--fg); }
    .brand .dot { width:11px; height:11px; border-radius:50%; background:linear-gradient(135deg,var(--accent),var(--accent2)); box-shadow:0 0 14px rgba(91,157,255,.7); }
    .nav-links { display:flex; gap:20px; align-items:center; font-size:14px; }
    .nav-links a { color:var(--muted); } .nav-links a:hover { color:var(--fg); }
    .nav-gh { color:var(--fg)!important; }
    @media(max-width:760px){ .nav-links a:not(.nav-gh){ display:none; } }

    .hero { padding:72px 0 40px; text-align:center; }
    .pill { display:inline-block; font-size:13px; padding:6px 14px; border:1px solid var(--border2);
      border-radius:999px; color:var(--muted); background:var(--panel2); }
    .hero h1 { font-size:clamp(34px,6vw,58px); line-height:1.05; margin:20px 0 0; font-weight:800; }
    .hero h1 .grad { text-decoration:none; }
    .tagline { color:var(--muted); font-size:clamp(16px,2.2vw,19px); max-width:680px; margin:18px auto 0; }
    .cta { margin-top:28px; display:flex; gap:12px; justify-content:center; flex-wrap:wrap; }
    .btn { padding:11px 20px; border-radius:11px; font-weight:600; font-size:15px; cursor:pointer;
      border:1px solid var(--border2); color:var(--fg); background:var(--panel); transition:.15s; }
    .btn:hover { transform:translateY(-1px); border-color:var(--accent); }
    .btn.primary { background:linear-gradient(95deg,var(--accent),var(--accent2)); color:#fff; border:none; box-shadow:0 6px 22px rgba(91,157,255,.32); }
    .btn.ghost { background:var(--panel); }
    .stats { margin-top:44px; display:grid; grid-template-columns:repeat(auto-fit,minmax(110px,1fr)); gap:14px; }
    .stat { background:var(--panel); border:1px solid var(--border); border-radius:var(--radius); padding:18px 12px; }
    .stat .n { font-size:30px; font-weight:800; background:linear-gradient(95deg,var(--accent),var(--accent2)); -webkit-background-clip:text; background-clip:text; color:transparent; }
    .stat .l { color:var(--muted); font-size:12px; text-transform:uppercase; letter-spacing:.6px; margin-top:2px; }
    .stat.skeleton .n { color:var(--muted); background:none; -webkit-text-fill-color:var(--muted); }

    section { padding:46px 0; border-top:1px solid var(--border); }
    .sec-head { margin-bottom:22px; }
    .sec-head h2 { font-size:26px; margin:0; }
    .sec-sub { color:var(--muted); margin:6px 0 0; font-size:15px; }
    .sec-sub code, .hiw code, footer code, .flow code { background:var(--panel2); padding:1px 6px; border-radius:6px; border:1px solid var(--border); font-size:.9em; }

    .pg { background:var(--panel); border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; }
    .pg-reqline { display:flex; align-items:center; gap:10px; padding:12px 18px; background:var(--panel2);
      border-bottom:1px solid var(--border); font-family:ui-monospace,monospace; font-size:14px; flex-wrap:wrap; }
    .pg-reqline .spacer { flex:1; }
    .method { color:var(--green); font-weight:700; }
    .status { font-size:13px; padding:2px 9px; border-radius:999px; }
    .status.ok { color:var(--green); background:rgba(126,231,135,.12); }
    .status.err { color:var(--red); background:rgba(255,123,138,.12); }
    .status.pending { color:var(--amber); }
    .pg-out { margin:0; padding:18px; max-height:440px; overflow:auto; background:var(--panel2); }
    .pg-out code { font-size:13px; line-height:1.55; white-space:pre; }
    .j-key { color:#8fbcff; } .j-str { color:var(--green); } .j-num { color:var(--amber); }
    .j-bool { color:#c792ea; } .j-null { color:var(--muted); }

    .hiw { display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:16px; }
    .hiw-card { background:var(--panel); border:1px solid var(--border); border-radius:var(--radius); padding:20px; }
    .hiw-card h3 { margin:0 0 6px; font-size:17px; } .hiw-card p { margin:0 0 12px; color:var(--muted); font-size:14px; }
    .pillar { display:flex; flex-direction:column; gap:8px; }
    .pillar-row { display:flex; justify-content:space-between; align-items:center; }
    .pillar.pending { border-style:dashed; }
    .pillar .badge { font-size:11px; padding:2px 8px; border-radius:999px; background:var(--panel2); color:var(--amber); border:1px solid var(--border2); text-transform:uppercase; letter-spacing:.4px; }
    .pillar .cmd { display:block; background:var(--panel2); border:1px solid var(--border); border-radius:8px; padding:8px 11px; font-size:13px; color:var(--green); }
    .pillar .more { font-size:13px; color:var(--accent); align-self:flex-start; }

    .flow { display:flex; gap:18px; align-items:stretch; flex-wrap:wrap; }
    .flow-card { flex:1; min-width:220px; background:var(--panel); border:1px solid var(--border); border-radius:var(--radius); padding:18px; }
    .flow-head { font-weight:700; font-size:15px; margin-bottom:10px; color:var(--fg); }
    .flow-body { font-size:14px; color:var(--muted); line-height:1.8; }
    .flow-arrow { display:flex; flex-direction:column; align-items:center; justify-content:center; min-width:120px; padding:14px 0; gap:4px; }
    .flow-arrow-line { font-size:30px; color:var(--accent); line-height:1; }
    .flow-arrow-label { font-size:11px; color:var(--fg); text-transform:uppercase; letter-spacing:.5px; }

    ul.ep { list-style:none; padding:0; margin:0; display:grid; gap:8px; }
    ul.ep a { display:flex; align-items:center; gap:12px; background:var(--panel); border:1px solid var(--border);
      border-radius:10px; padding:11px 15px; color:var(--fg); transition:.14s; }
    ul.ep a:hover { border-color:var(--accent); transform:translateX(3px); }
    .ep-path { font-family:ui-monospace,monospace; font-size:14px; }
    .ep-desc { margin-left:auto; color:var(--muted); font-size:13px; }
    @media(max-width:560px){ .ep-desc{ display:none; } }

    footer { padding:48px 22px; text-align:center; color:var(--muted); font-size:14px; border-top:1px solid var(--border); }
    footer p { margin:6px 0; } footer strong { color:var(--fg); }
  </style>
</body>
</html>
